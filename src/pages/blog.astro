---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// Placeholder posts — replace with real content or a CMS
const posts = [
  {
    slug: 'best-ways-send-money-latin-america',
    title: 'Best ways to send money to Latin America in 2026',
    excerpt: 'A fintech-backed comparison of Wise, Remitly, and local options — ranked by fees, speed, and reliability.',
    category: 'Global Money',
    date: 'May 2026',
  },
  {
    slug: 'expat-banking-guide',
    title: 'The expat banking guide: accounts that work anywhere',
    excerpt: 'Multi-currency accounts, digital banks, and what to look for when you live across borders.',
    category: 'Expat Finance',
    date: 'May 2026',
  },
  {
    slug: 'cost-of-living-mexico-city',
    title: 'Cost of living in Mexico City for remote workers',
    excerpt: 'A real breakdown of rent, food, transport, and healthcare — updated for 2026.',
    category: 'Place & Culture',
    date: 'Apr 2026',
  },
];
---

<BaseLayout title="Articles — GeoPueblo">
  <header class="blog-header">
    <Nav />
    <div class="blog-header-content">
      <h1>Articles</h1>
      <p>Guides, stories, and insights for the globally curious</p>
    </div>
  </header>

  <main class="blog-main">
    <div class="posts">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="post-card">
          <span class="post-category">{post.category}</span>
          <h2>{post.title}</h2>
          <p>{post.excerpt}</p>
          <span class="post-date">{post.date}</span>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blog-header {
    position: relative;
    background: var(--color-dark-mid);
    padding: 5rem 2rem 3rem;
    text-align: center;
    overflow: hidden;
  }

  .blog-header-content {
    position: relative;
    z-index: 1;
  }

  .blog-header h1 {
    font-size: 36px;
    font-weight: 500;
    color: var(--color-cream);
    margin-bottom: 0.5rem;
  }

  .blog-header p {
    font-size: 16px;
    color: var(--color-muted);
  }

  .blog-main {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .posts {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .post-card {
    display: block;
    background: var(--color-gray-lt);
    border: 1px solid #EDE5DA;
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-decoration: none;
    transition: transform 0.2s;
  }

  .post-card:hover {
    transform: translateY(-2px);
    text-decoration: none;
  }

  .post-category {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-terra);
  }

  .post-card h2 {
    font-size: 20px;
    font-weight: 500;
    color: var(--color-text);
    margin: 8px 0;
    line-height: 1.3;
  }

  .post-card p {
    font-size: 15px;
    color: var(--color-gray-mid);
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .post-date {
    font-size: 13px;
    color: #B0957E;
  }
</style>
