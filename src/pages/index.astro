---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const pillars = [
  {
    icon: '💸',
    en_title: 'Global Money',    es_title: 'Dinero Global',
    en_desc: 'Send, receive, and grow money across borders — smarter, faster, and with fewer fees wherever you are.',
    es_desc: 'Envía, recibe y haz crecer tu dinero sin fronteras — más inteligente, más rápido y con menos comisiones.',
    href: '/money',
  },
  {
    icon: '📦',
    en_title: 'Global Goods',    es_title: 'Productos Globales',
    en_desc: 'Access food, health, and everyday products from around the world — delivered to your door, no matter where that is.',
    es_desc: 'Accede a alimentos, productos de salud y artículos del hogar de todo el mundo — entregados en tu puerta.',
    href: '/goods',
  },
  {
    icon: '🌐',
    en_title: 'Global Services',  es_title: 'Servicios Globales',
    en_desc: 'Find the platforms, tools, and professionals that work across borders — from banking to healthcare to remote work.',
    es_desc: 'Encuentra plataformas, herramientas y profesionales que funcionan sin fronteras — de la banca a la salud.',
    href: '/services',
  },
  {
    icon: '✈️',
    en_title: 'Global Travel',    es_title: 'Viajes Globales',
    en_desc: 'Navigate the world with confidence — visas, flights, accommodation, and local tips for the cross-border traveler.',
    es_desc: 'Navega el mundo con confianza — visas, vuelos, alojamiento y consejos locales para el viajero internacional.',
    href: '/travel',
  },
  {
    icon: '🤝',
    en_title: 'Global Community', es_title: 'Comunidad Global',
    en_desc: 'Connect with others navigating life between cultures — shared stories, local knowledge, and a village that spans the world.',
    es_desc: 'Conéctate con quienes navegan la vida entre culturas — historias compartidas y un pueblo que abarca el mundo.',
    href: '/community',
  },
];

// Free Unsplash city photos — all free for commercial use, no attribution required
const cityPhotos = [
  { id: 'photo-1538970272646-f61fabb3a8a2', city: 'Tokyo' },
  { id: 'photo-1513635269975-59663e0ac1ad', city: 'London' },
  { id: 'photo-1547981609-4b6bfe67ca0b', city: 'New York' },
  { id: 'photo-1502602898657-3e91760cbb34', city: 'Paris' },
  { id: 'photo-1512453979798-5ea266f8880c', city: 'Dubai' },
  { id: 'photo-1534430480872-3498386e7856', city: 'São Paulo' },
];

const topics = [
  'Sending money home',
  'Best expat banks',
  'Package forwarding',
  'Health products globally',
  'Remote work tools',
  'Cross-border travel tips',
  'Diaspora community',
  'Multi-currency accounts',
];
---

<BaseLayout>
  <!-- HERO -->
  <section class="hero">
    <Nav />
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">GeoPueblo</p>
      <h1>
        <span class="t-en">The world is<br>your <span>pueblo</span></span>
        <span class="t-es" style="display:none">El mundo es<br>tu <span>pueblo</span></span>
      </h1>
      <p class="hero-sub">
        <span class="t-en">Explore money, culture, and life across borders —
        for the globally curious and financially savvy.</span>
        <span class="t-es" style="display:none">Explora dinero, cultura y vida sin fronteras —
        para el curioso global y el inteligente financiero.</span>
      </p>
      <div class="hero-cta">
        <a href="/blog" class="btn-primary">
          <span class="t-en">Start exploring</span>
          <span class="t-es" style="display:none">Explorar ahora</span>
        </a>
        <a href="#subscribe" class="btn-secondary">
          <span class="t-en">Join the village</span>
          <span class="t-es" style="display:none">Únete al pueblo</span>
        </a>
      </div>
    </div>
  </section>

  <!-- BAND -->
  <div class="band">
    <p>
      <span class="t-en">🌎 &nbsp; Global Money &nbsp;·&nbsp; Global Goods &nbsp;·&nbsp; Global Services &nbsp;·&nbsp; Global Travel &nbsp;·&nbsp; Global Community</span>
      <span class="t-es" style="display:none">🌎 &nbsp; Dinero Global &nbsp;·&nbsp; Productos &nbsp;·&nbsp; Servicios &nbsp;·&nbsp; Viajes &nbsp;·&nbsp; Comunidad</span>
    </p>
  </div>

  <!-- PILLARS with city photo rotator background -->
  <section class="pillars-section">

    <!-- City photo rotator -->
    <div class="city-rotator" id="cityRotator">
      {cityPhotos.map((photo, i) => (
        <div
          class={`city-slide ${i === 0 ? 'active' : ''}`}
          style={`background-image: url('https://images.unsplash.com/${photo.id}?w=1400&q=70&auto=format&fit=crop')`}
          data-city={photo.city}
        ></div>
      ))}
      <div class="city-overlay"></div>
      <div class="city-label" id="cityLabel">{cityPhotos[0].city}</div>
      <div class="city-dots">
        {cityPhotos.map((_, i) => (
          <button class={`city-dot ${i === 0 ? 'active' : ''}`} data-index={i} aria-label={`Show ${cityPhotos[i].city}`}></button>
        ))}
      </div>
    </div>

    <div class="section pillars-inner">
      <h2 class="section-title">
        <span class="t-en">What is GeoPueblo?</span>
        <span class="t-es" style="display:none">¿Qué es GeoPueblo?</span>
      </h2>
      <p class="section-sub">
        <span class="t-en">Your guide to living, moving, and thriving across the world's villages</span>
        <span class="t-es" style="display:none">Tu guía para vivir, moverse y prosperar en los pueblos del mundo</span>
      </p>
      <div class="pillars">
        {pillars.map(p => (
          <a href={p.href} class="pillar">
            <div class="pillar-icon">{p.icon}</div>
            <h3>
              <span class="t-en">{p.en_title}</span>
              <span class="t-es" style="display:none">{p.es_title}</span>
            </h3>
            <p>
              <span class="t-en">{p.en_desc}</span>
              <span class="t-es" style="display:none">{p.es_desc}</span>
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script>
    const slides = document.querySelectorAll('.city-slide');
    const dots   = document.querySelectorAll('.city-dot');
    const label  = document.getElementById('cityLabel');
    let current  = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(n: number) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = n;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
      if (label) label.textContent = (slides[current] as HTMLElement).dataset.city || '';
    }

    function next() {
      goTo((current + 1) % slides.length);
    }

    function startTimer() {
      timer = setInterval(next, 4000);
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        clearInterval(timer);
        goTo(i);
        startTimer();
      });
    });

    startTimer();
  </script>

  <!-- FX TICKER -->
  <div class="fx-bar" id="fxBar">
    <div class="fx-track" id="fxTrack">
      <span class="fx-loading">Loading rates…</span>
    </div>
  </div>

  <!-- NEWS TICKER -->
  <div class="news-bar" id="newsBar">
    <div class="news-track-wrap">
      <div class="news-track" id="newsTrack">
        <span class="news-loading">Loading headlines…</span>
      </div>
    </div>
  </div>

  <script>
    // ── FX TICKER ──────────────────────────────────────────────
    // Frankfurter API — free, no key, ECB data
    // Focus on currencies relevant to GeoPueblo's markets
    const FX_PAIRS = [
      { from: 'USD', to: 'EUR',  label: 'EUR/USD' },
      { from: 'USD', to: 'GBP',  label: 'GBP/USD' },
      { from: 'USD', to: 'COP',  label: 'USD/COP' },
      { from: 'USD', to: 'HNL',  label: 'USD/HNL' },
      { from: 'USD', to: 'GTQ',  label: 'USD/GTQ' },
      { from: 'USD', to: 'CAD',  label: 'USD/CAD' },
      { from: 'USD', to: 'BRL',  label: 'USD/BRL' },
      { from: 'USD', to: 'MXN',  label: 'USD/MXN' },
      { from: 'USD', to: 'JPY',  label: 'USD/JPY' },
      { from: 'USD', to: 'CNY',  label: 'USD/CNY' },
    ];

    async function loadFX() {
      const track = document.getElementById('fxTrack');
      if (!track) return;
      try {
        const res  = await fetch('https://api.frankfurter.dev/v2/latest?base=USD&symbols=EUR,GBP,COP,HNL,GTQ,CAD,BRL,MXN,JPY,CNY');
        const data = await res.json();
        const rates = data.rates;
        const items = FX_PAIRS
          .filter(p => rates[p.to])
          .map(p => {
            const rate = rates[p.to];
            const fmt  = rate >= 100
              ? rate.toFixed(2)
              : rate >= 10
                ? rate.toFixed(3)
                : rate.toFixed(4);
            return `<span class="fx-item"><span class="fx-pair">${p.label}</span><span class="fx-rate">${fmt}</span></span>`;
          }).join('<span class="fx-sep">·</span>');
        // Double up for seamless loop
        track.innerHTML = `<div class="fx-scroll">${items}<span class="fx-sep">·</span>${items}</div>`;
      } catch {
        track.innerHTML = '<span class="fx-loading">Rates unavailable</span>';
      }
    }

    // ── NEWS TICKER ────────────────────────────────────────────
    // rss2json.com — free CORS proxy for BBC World News RSS
    async function loadNews() {
      const track = document.getElementById('newsTrack');
      if (!track) return;
      try {
        const rss = 'https://feeds.bbci.co.uk/news/world/rss.xml';
        const url = `https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(rss)}&count=15`;
        const res  = await fetch(url);
        const data = await res.json();
        if (!data.items?.length) throw new Error('No items');
        const items = data.items
          .map((item: any) => `<a class="news-item" href="${item.link}" target="_blank" rel="noopener">${item.title}</a>`)
          .join('<span class="news-sep">◆</span>');
        // Double up for seamless loop
        track.innerHTML = `${items}<span class="news-sep">◆</span>${items}`;
      } catch {
        // Fallback headlines if API unavailable
        const fallback = [
          'GeoPueblo: The world is your pueblo',
          'Cross-border commerce connecting the Latin American diaspora',
          'Global goods, money, services and travel — one platform',
        ];
        const items = fallback.map(h => `<span class="news-item">${h}</span>`).join('<span class="news-sep">◆</span>');
        track.innerHTML = `${items}<span class="news-sep">◆</span>${items}`;
      }
    }

    loadFX();
    loadNews();
    // Refresh FX every 5 minutes
    setInterval(loadFX, 300000);
  </script>

  <hr class="divider" />

  <!-- FREE MEMBERSHIP -->
  <section class="section membership-section" id="subscribe">
    <div class="membership-badge">
      <span class="t-en">🎉 Free Membership</span>
      <span class="t-es" style="display:none">🎉 Membresía Gratuita</span>
    </div>
    <h2 class="section-title">
      <span class="t-en">Join GeoPueblo — it's free</span>
      <span class="t-es" style="display:none">Únete a GeoPueblo — es gratis</span>
    </h2>
    <p class="section-sub">
      <span class="t-en">Get guides, tips, exclusive deals, and stories — in English and Spanish.</span>
      <span class="t-es" style="display:none">Recibe guías, consejos, ofertas exclusivas e historias — en inglés y español.</span>
    </p>
    <div class="membership-perks">
      <div class="perk">
        <span class="perk-icon">💸</span>
        <span class="t-en">Money transfer guides</span>
        <span class="t-es" style="display:none">Guías de transferencias</span>
      </div>
      <div class="perk">
        <span class="perk-icon">📦</span>
        <span class="t-en">Members-only box deals</span>
        <span class="t-es" style="display:none">Ofertas exclusivas de cajas</span>
      </div>
      <div class="perk">
        <span class="perk-icon">✈️</span>
        <span class="t-en">Travel club discounts</span>
        <span class="t-es" style="display:none">Descuentos de club de viajes</span>
      </div>
      <div class="perk">
        <span class="perk-icon">🤝</span>
        <span class="t-en">Community stories</span>
        <span class="t-es" style="display:none">Historias de comunidad</span>
      </div>
    </div>
    <form class="subscribe-form" action="#" method="POST">
      <input type="email" name="email" placeholder="your@email.com" required />
      <button type="submit">
        <span class="t-en">Get free access</span>
        <span class="t-es" style="display:none">Acceso gratuito</span>
      </button>
    </form>
    <p class="subscribe-note">
      <span class="t-en">No spam. No credit card. Unsubscribe anytime.</span>
      <span class="t-es" style="display:none">Sin spam. Sin tarjeta. Cancela cuando quieras.</span>
    </p>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 2rem 5rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1695596254299-c541eee4eef7?w=1400&q=80');
    background-size: cover;
    background-position: center 50%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(30, 15, 5, 0.70);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 600px;
  }

  .hero-eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 4px;
    color: var(--color-terra-lt);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .hero h1 {
    font-size: clamp(36px, 6vw, 52px);
    font-weight: 600;
    color: var(--color-cream);
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .hero h1 span {
    color: var(--color-terra-lt);
  }

  .hero-sub {
    font-size: 17px;
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--color-terra-lt);
    color: var(--color-dark);
    font-size: 15px;
    font-weight: 500;
    padding: 13px 28px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-primary:hover {
    background: #fff;
    text-decoration: none;
  }

  .btn-secondary {
    background: rgba(255,255,255,0.12);
    color: var(--color-cream);
    font-size: 15px;
    padding: 13px 28px;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255,255,255,0.3);
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.22);
    text-decoration: none;
  }

  /* BAND */
  .band {
    background: var(--color-terra-lt);
    padding: 10px 2rem;
    text-align: center;
  }

  .band p {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-dark);
    letter-spacing: 0.5px;
  }

  /* SECTIONS */
  .section {
    padding: 4rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 26px;
    font-weight: 500;
    color: var(--color-text);
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .section-sub {
    font-size: 16px;
    color: var(--color-gray-mid);
    text-align: center;
    margin-bottom: 2.5rem;
  }

  /* PILLARS SECTION */
  .pillars-section {
    position: relative;
    overflow: hidden;
  }

  /* CITY ROTATOR */
  .city-rotator {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .city-slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 1.2s ease;
  }

  .city-slide.active {
    opacity: 1;
  }

  .city-overlay {
    position: absolute;
    inset: 0;
    background: rgba(245, 240, 235, 0.82);
  }

  .city-label {
    position: absolute;
    bottom: 1rem;
    right: 1.5rem;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-terra);
    opacity: 0.7;
    z-index: 2;
  }

  .city-dots {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 2;
  }

  .city-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: #D4C4B4;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s;
  }

  .city-dot.active {
    background: var(--color-terra);
  }

  .pillars-inner {
    position: relative;
    z-index: 1;
    padding: 4rem 2rem 5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* PILLARS GRID */
  .pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
  }

  .pillar {
    background: var(--color-gray-lt);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    border: 1px solid #EDE5DA;
  }

  .pillar:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(30,15,5,0.08);
    text-decoration: none;
  }

  .pillar-icon {
    font-size: 28px;
    margin-bottom: 12px;
  }

  .pillar h3 {
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .pillar p {
    font-size: 14px;
    color: var(--color-gray-mid);
    line-height: 1.6;
  }

  .divider {
    border: none;
    border-top: 1px solid #EDE5DA;
    margin: 0;
  }

  /* FX TICKER */
  .fx-bar {
    background: #000;
    display: flex;
    align-items: center;
    overflow: hidden;
    height: 34px;
    border-bottom: 1px solid #222;
  }

  .fx-track {
    flex: 1;
    overflow: hidden;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 16px;
  }

  .fx-scroll {
    display: flex;
    align-items: center;
    white-space: nowrap;
    animation: fxScroll 40s linear infinite;
  }

  @keyframes fxScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .fx-item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 0 18px;
  }

  .fx-pair {
    font-size: 11px;
    font-weight: 700;
    color: #999;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .fx-rate {
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    font-variant-numeric: tabular-nums;
  }

  .fx-sep {
    color: #444;
    font-size: 10px;
    padding: 0 2px;
  }

  .fx-loading {
    font-size: 12px;
    color: #666;
    padding: 0 16px;
  }

  /* NEWS TICKER */
  .news-bar {
    background: #111;
    display: flex;
    align-items: center;
    overflow: hidden;
    height: 36px;
    border-bottom: 2px solid var(--color-terra);
  }

  .news-track-wrap {
    flex: 1;
    overflow: hidden;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 16px;
  }

  .news-track {
    display: flex;
    align-items: center;
    white-space: nowrap;
    animation: newsScroll 60s linear infinite;
  }

  .news-track:hover {
    animation-play-state: paused;
  }

  @keyframes newsScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .news-item {
    display: inline-block;
    font-size: 13px;
    font-weight: 500;
    color: #fff;
    padding: 0 22px;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .news-item:hover {
    color: var(--color-terra-lt);
    text-decoration: none;
  }

  .news-sep {
    color: var(--color-terra);
    font-size: 10px;
    padding: 0 2px;
    opacity: 0.9;
  }

  .news-loading {
    font-size: 12px;
    color: #666;
    padding: 0 16px;
  }

  /* MEMBERSHIP SECTION */
  .membership-section {
    text-align: center;
    background: var(--color-gray-lt);
    max-width: 100%;
    padding: 4rem 2rem;
    border-top: 1px solid #EDE5DA;
  }

  .membership-badge {
    display: inline-block;
    background: var(--color-terra);
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 20px;
    margin-bottom: 1rem;
  }

  .membership-section .section-title {
    font-size: 28px;
    margin-bottom: 0.5rem;
  }

  .membership-perks {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin: 1.5rem auto;
    max-width: 600px;
  }

  .perk {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #fff;
    border: 1px solid #EDE5DA;
    border-radius: 20px;
    padding: 7px 14px;
    font-size: 13px;
    color: var(--color-text);
  }

  .perk-icon {
    font-size: 14px;
  }

  .subscribe-form {
    display: flex;
    gap: 8px;
    max-width: 440px;
    margin: 0 auto;
  }

  .subscribe-form input {
    flex: 1;
