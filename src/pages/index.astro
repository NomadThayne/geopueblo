---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const pillars = [
  {
    icon: '💸',
    en_title: 'Global Money',    es_title: 'Dinero Global',
    en_desc: 'Send, receive, and grow money across borders — smarter, faster, and with fewer fees wherever you are.',
    es_desc: 'Envía, recibe y haz crecer tu dinero sin fronteras — más inteligente, más rápido y con menos comisiones.',
    href: '/money',
  },
  {
    icon: '📦',
    en_title: 'Global Goods',    es_title: 'Productos Globales',
    en_desc: 'Access food, health, and everyday products from around the world — delivered to your door, no matter where that is.',
    es_desc: 'Accede a alimentos, productos de salud y artículos del hogar de todo el mundo — entregados en tu puerta.',
    href: '/goods',
  },
  {
    icon: '🌐',
    en_title: 'Global Services',  es_title: 'Servicios Globales',
    en_desc: 'Find the platforms, tools, and professionals that work across borders — from banking to healthcare to remote work.',
    es_desc: 'Encuentra plataformas, herramientas y profesionales que funcionan sin fronteras — de la banca a la salud.',
    href: '/services',
  },
  {
    icon: '✈️',
    en_title: 'Global Travel',    es_title: 'Viajes Globales',
    en_desc: 'Navigate the world with confidence — visas, flights, accommodation, and local tips for the cross-border traveler.',
    es_desc: 'Navega el mundo con confianza — visas, vuelos, alojamiento y consejos locales para el viajero internacional.',
    href: '/travel',
  },
  {
    icon: '🤝',
    en_title: 'Global Community', es_title: 'Comunidad Global',
    en_desc: 'Connect with others navigating life between cultures — shared stories, local knowledge, and a village that spans the world.',
    es_desc: 'Conéctate con quienes navegan la vida entre culturas — historias compartidas y un pueblo que abarca el mundo.',
    href: '/community',
  },
];

// Free Unsplash city photos — all free for commercial use, no attribution required
const cityPhotos = [
  { id: 'photo-1538970272646-f61fabb3a8a2', city: 'Tokyo' },
  { id: 'photo-1513635269975-59663e0ac1ad', city: 'London' },
  { id: 'photo-1547981609-4b6bfe67ca0b', city: 'New York' },
  { id: 'photo-1502602898657-3e91760cbb34', city: 'Paris' },
  { id: 'photo-1512453979798-5ea266f8880c', city: 'Dubai' },
  { id: 'photo-1534430480872-3498386e7856', city: 'São Paulo' },
];

const topics = [
  'Sending money home',
  'Best expat banks',
  'Package forwarding',
  'Health products globally',
  'Remote work tools',
  'Cross-border travel tips',
  'Diaspora community',
  'Multi-currency accounts',
];
---

<BaseLayout>
  <!-- HERO -->
  <section class="hero">
    <Nav />
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">GeoPueblo</p>
      <h1>
        <span class="t-en">The world is<br>your <span>pueblo</span></span>
        <span class="t-es" style="display:none">El mundo es<br>tu <span>pueblo</span></span>
      </h1>
      <p class="hero-sub">
        <span class="t-en">Explore money, culture, and life across borders.</span>
        <span class="t-es" style="display:none">Explora dinero, cultura y vida sin fronteras.</span>
      </p>
      <div class="hero-cta">
        <a href="/blog" class="btn-primary">
          <span class="t-en">Start exploring</span>
          <span class="t-es" style="display:none">Explorar ahora</span>
        </a>
        <a href="#subscribe" class="btn-secondary">
          <span class="t-en">Join the village</span>
          <span class="t-es" style="display:none">Únete al pueblo</span>
        </a>
      </div>
    </div>
  </section>

  <!-- BAND -->
  <div class="band">
    <p>
      <span class="t-en">🌎 &nbsp; Global Money &nbsp;·&nbsp; Global Goods &nbsp;·&nbsp; Global Services &nbsp;·&nbsp; Global Travel &nbsp;·&nbsp; Global Community</span>
      <span class="t-es" style="display:none">🌎 &nbsp; Dinero Global &nbsp;·&nbsp; Productos &nbsp;·&nbsp; Servicios &nbsp;·&nbsp; Viajes &nbsp;·&nbsp; Comunidad</span>
    </p>
  </div>

  <!-- PILLARS with city photo rotator background -->
  <section class="pillars-section">

    <!-- City photo rotator -->
    <div class="city-rotator" id="cityRotator">
      {cityPhotos.map((photo, i) => (
        <div
          class={`city-slide ${i === 0 ? 'active' : ''}`}
          style={`background-image: url('https://images.unsplash.com/${photo.id}?w=1400&q=70&auto=format&fit=crop')`}
          data-city={photo.city}
        ></div>
      ))}
      <div class="city-overlay"></div>
      <div class="city-label" id="cityLabel">{cityPhotos[0].city}</div>
      <div class="city-dots">
        {cityPhotos.map((_, i) => (
          <button class={`city-dot ${i === 0 ? 'active' : ''}`} data-index={i} aria-label={`Show ${cityPhotos[i].city}`}></button>
        ))}
      </div>
    </div>

    <div class="section pillars-inner">
      <h2 class="section-title">
        <span class="t-en">What is GeoPueblo?</span>
        <span class="t-es" style="display:none">¿Qué es GeoPueblo?</span>
      </h2>
      <p class="section-sub">
        <span class="t-en">Your guide to living, moving, and thriving across the world's villages</span>
        <span class="t-es" style="display:none">Tu guía para vivir, moverse y prosperar en los pueblos del mundo</span>
      </p>
      <div class="pillars">
        {pillars.map(p => (
          <a href={p.href} class="pillar">
            <div class="pillar-icon">{p.icon}</div>
            <h3>
              <span class="t-en">{p.en_title}</span>
              <span class="t-es" style="display:none">{p.es_title}</span>
            </h3>
            <p>
              <span class="t-en">{p.en_desc}</span>
              <span class="t-es" style="display:none">{p.es_desc}</span>
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script>
    const slides = document.querySelectorAll('.city-slide');
    const dots   = document.querySelectorAll('.city-dot');
    const label  = document.getElementById('cityLabel');
    let current  = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(n: number) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = n;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
      if (label) label.textContent = (slides[current] as HTMLElement).dataset.city || '';
    }

    function next() {
      goTo((current + 1) % slides.length);
    }

    function startTimer() {
      timer = setInterval(next, 4000);
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        clearInterval(timer);
        goTo(i);
        startTimer();
      });
    });

    startTimer();
  </script>

  </section>

  <!-- FX TICKER -->
  <div class="fx-bar" id="fxBar">
    <div class="fx-track" id="fxTrack">
      <span class="fx-loading">Loading rates…</span>
    </div>
  </div>

  <!-- NEWS TICKER -->
  <div class="news-bar" id="newsBar">
    <div class="news-track-wrap">
      <div class="news-track" id="newsTrack">
        <span class="news-loading">Loading headlines…</span>
      </div>
    </div>
  </div>

  <script>
    // ── CONFIG ─────────────────────────────────────────────────
    // After deploying the worker (see workers/ticker.js), replace
    // this URL with your actual worker URL:
    // e.g. https://geopueblo-ticker.YOUR-SUBDOMAIN.workers.dev
    const WORKER_URL = 'https://geopueblo-ticker.thayne.workers.dev';

    const FX_PAIRS = [
      { to: 'EUR', label: 'EUR/USD' },
      { to: 'GBP', label: 'GBP/USD' },
      { to: 'COP', label: 'USD/COP' },
      { to: 'HNL', label: 'USD/HNL' },
      { to: 'GTQ', label: 'USD/GTQ' },
      { to: 'CAD', label: 'USD/CAD' },
      { to: 'BRL', label: 'USD/BRL' },
      { to: 'MXN', label: 'USD/MXN' },
      { to: 'JPY', label: 'USD/JPY' },
      { to: 'CNY', label: 'USD/CNY' },
    ];

    // Hardcoded fallback rates (updated May 2026) — always visible
    const FALLBACK_RATES: Record<string, number> = {
      EUR: 0.9201, GBP: 0.7891, COP: 4185.0, HNL: 24.89,
      GTQ: 7.74,   CAD: 1.3642, BRL: 5.1820, MXN: 17.12,
      JPY: 155.42, CNY: 7.2450
    };

    function buildFXHtml(rates: Record<string, number>) {
      const items = FX_PAIRS.map(p => {
        const rate = rates[p.to];
        if (!rate) return '';
        const fmt = rate >= 100 ? rate.toFixed(2) : rate >= 10 ? rate.toFixed(3) : rate.toFixed(4);
        return `<span class="fx-item"><span class="fx-pair">${p.label}</span><span class="fx-rate">${fmt}</span></span>`;
      }).filter(Boolean);
      const sep = '<span class="fx-sep">|</span>';
      // Repeat enough times that the content is always wider than the viewport.
      // translateX(-50%) loops back to start — both halves must be identical.
      const REPEATS = 6; // 10 pairs × 6 = 60 items per half, well over any screen width
      const half = Array(REPEATS).fill(items.join(sep)).join(sep) + sep;
      return `<div class="fx-scroll">${half}${half}</div>`;
    }

    async function loadFX() {
      const track = document.getElementById('fxTrack');
      if (!track) return;
      // Show fallback immediately so bars are never empty
      track.innerHTML = buildFXHtml(FALLBACK_RATES);
      try {
        const res  = await fetch(`${WORKER_URL}/api/fx`);
        const data = await res.json();
        if (data.rates) track.innerHTML = buildFXHtml(data.rates);
      } catch { /* keep fallback */ }
    }

    // Hardcoded fallback headlines — always visible
    const FALLBACK_HEADLINES = [
      { title: 'GeoPueblo: Connecting the Latin American diaspora to the world', link: '#' },
      { title: 'Send money, goods, and travel — all in one platform', link: '#' },
      { title: 'Venezuela · Cuba · Haiti · Honduras · Guatemala · El Salvador · Colombia', link: '#' },
      { title: 'Free membership — join the GeoPueblo village today', link: '#' },
    ];

    function buildNewsHtml(items: Array<{title: string, link: string}>) {
      const html = items.map(i =>
        `<a class="news-item" href="${i.link}" target="_blank" rel="noopener">${i.title}</a>`
      ).join('<span class="news-sep">◆</span>');
      // Base speed on total character count — ~0.13s per character feels right
      const totalChars = items.reduce((sum, i) => sum + i.title.length, 0);
      const duration = Math.max(90, Math.round(totalChars * 0.13));
      return `<div class="news-scroll" style="animation: newsScroll ${duration}s linear infinite; display:flex; align-items:center; white-space:nowrap;">${html}<span class="news-sep">◆</span>${html}</div>`;
    }

    async function loadNews(lang = 'en') {
      const track = document.getElementById('newsTrack');
      if (!track) return;
      // Show fallback immediately
      track.innerHTML = buildNewsHtml(FALLBACK_HEADLINES);
      try {
        const endpoint = lang === 'es' ? `${WORKER_URL}/api/news-es` : `${WORKER_URL}/api/news`;
        const res  = await fetch(endpoint);
        const data = await res.json();
        if (data.items?.length) track.innerHTML = buildNewsHtml(data.items);
      } catch { /* keep fallback */ }
    }

    loadFX();
    loadNews(localStorage.getItem('gp-lang') || 'en');
    setInterval(loadFX, 300000);
    setInterval(() => loadNews(localStorage.getItem('gp-lang') || 'en'), 300000);

    // Reload news when language toggles
    document.getElementById('langToggle')?.addEventListener('click', () => {
      setTimeout(() => loadNews(localStorage.getItem('gp-lang') || 'en'), 100);
    });
  </script>

  <hr class="divider" />

  <!-- FREE MEMBERSHIP -->
  <section class="section membership-section" id="subscribe">
    <div class="membership-badge">
      <span class="t-en">🎉 Free Membership</span>
      <span class="t-es" style="display:none">🎉 Membresía Gratuita</span>
    </div>
    <h2 class="section-title">
      <span class="t-en">Join GeoPueblo — it's free</span>
      <span class="t-es" style="display:none">Únete a GeoPueblo — es gratis</span>
    </h2>
    <p class="section-sub">
      <span class="t-en">Get guides, tips, exclusive deals, and stories — in English and Spanish.</span>
      <span class="t-es" style="display:none">Recibe guías, consejos, ofertas exclusivas e historias — en inglés y español.</span>
    </p>
    <div class="membership-perks">
      <div class="perk">
        <span class="perk-icon">💸</span>
        <span class="t-en">Money transfer guides</span>
        <span class="t-es" style="display:none">Guías de transferencias</span>
      </div>
      <div class="perk">
        <span class="perk-icon">📦</span>
        <span class="t-en">Members-only box deals</span>
        <span class="t-es" style="display:none">Ofertas exclusivas de cajas</span>
      </div>
      <div class="perk">
        <span class="perk-icon">✈️</span>
        <span class="t-en">Travel club discounts</span>
        <span class="t-es" style="display:none">Descuentos de club de viajes</span>
      </div>
      <div class="perk">
        <span class="perk-icon">🤝</span>
        <span class="t-en">Community stories</span>
        <span class="t-es" style="display:none">Historias de comunidad</span>
      </div>
    </div>
    <form class="subscribe-form" action="#" method="POST">
      <input type="email" name="email" placeholder="your@email.com" required />
      <button type="submit">
        <span class="t-en">Get free access</span>
        <span class="t-es" style="display:none">Acceso gratuito</span>
      </button>
    </form>
    <p class="subscribe-note">
      <span class="t-en">No spam. No credit card. Unsubscribe anytime.</span>
      <span class="t-es" style="display:none">Sin spam. Sin tarjeta. Cancela cuando quieras.</span>
    </p>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 2rem 5rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1695596254299-c541eee4eef7?w=1400&q=80');
    background-size: cover;
    background-position: center 50%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(30, 15, 5, 0.70);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 600px;
  }

  .hero-eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 4px;
    color: var(--color-terra-lt);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .hero h1 {
    font-size: clamp(36px, 6vw, 52px);
    font-weight: 600;
    color: var(--color-cream);
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .hero h1 span {
    color: var(--color-terra-lt);
  }

  .hero-sub {
    font-size: 17px;
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--color-terra-lt);
    color: var(--color-dark);
    font-size: 15px;
    font-weight: 500;
    padding: 13px 28px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-primary:hover {
    background: #fff;
    text-decoration: none;
  }

  .btn-secondary {
    background: rgba(255,255,255,0.12);
    color: var(--color-cream);
    font-size: 15px;
    padding: 13px 28px;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255,255,255,0.3);
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.22);
    text-decoration: none;
  }

  /* BAND */
  .band {
    background: var(--color-terra-lt);
    padding: 10px 2rem;
    text-align: center;
  }

  .band p {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-dark);
    letter-spacing: 0.5px;
  }

  /* SECTIONS */
  .section {
    padding: 4rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 26px;
    font-weight: 500;
    color: var(--color-text);
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .section-sub {
    font-size: 16px;
    color: var(--color-gray-mid);
    text-align: center;
    margin-bottom: 2.5rem;
  }

  /* PILLARS SECTION */
  .pillars-section {
    position: relative;
    overflow: hidden;
  }

  /* CITY ROTATOR */
  .city-rotator {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .city-slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 1.2s ease;
  }

  .city-slide.active {
    opacity: 1;
  }

  .city-overlay {
    position: absolute;
    inset: 0;
    background: rgba(245, 240, 235, 0.82);
  }

  .city-label {
    position: absolute;
    bottom: 1rem;
    right: 1.5rem;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-terra);
    opacity: 0.7;
    z-index: 2;
  }

  .city-dots {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 2;
  }

  .city-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: #D4C4B4;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s;
  }

  .city-dot.active {
    background: var(--color-terra);
  }

  .pillars-inner {
    position: relative;
    z-index: 1;
    padding: 4rem 2rem 5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* PILLARS GRID */
  .pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
  }

  .pillar {
    background: var(--color-gray-lt);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    border: 1px solid #EDE5DA;
  }

  .pillar:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(30,15,5,0.08);
    text-decoration: none;
  }

  .pillar-icon {
    font-size: 28px;
    margin-bottom: 12px;
  }

  .pillar h3 {
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .pillar p {
    font-size: 14px;
    color: var(--color-gray-mid);
    line-height: 1.6;
  }

  .divider {
    border: none;
    border-top: 1px solid #EDE5DA;
    margin: 0;
  }

  /* FX TICKER — static shell (scoped ok) */
  .fx-bar {
    background: #000;
    height: 40px;
    overflow: hidden;
    display: flex;
    align-items: center;
    z-index: 10;
    border-bottom: 2px solid #333;
  }

  .fx-track {
    display: flex;
    align-items: center;
    width: 100%;
    overflow: hidden;
    height: 100%;
  }

  @keyframes fxScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* JS-injected elements need :global() — Astro scoping won't reach them otherwise */
  :global(.fx-scroll) {
    display: inline-flex;
    align-items: center;
    height: 40px;
    white-space: nowrap;
    will-change: transform;
    animation: fxScroll 320s linear infinite;
  }
  :global(.fx-scroll:hover) { animation-play-state: paused; }
  :global(.fx-item) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0 20px;
    flex-shrink: 0;
  }
  :global(.fx-pair) {
    font-family: monospace;
    font-size: 12px;
    font-weight: 700;
    color: #FFD580;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  :global(.fx-rate) {
    font-family: monospace;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    font-variant-numeric: tabular-nums;
  }
  :global(.fx-sep) { color: #555; font-size: 14px; padding: 0 6px; }
  :global(.fx-loading) {
    font-family: monospace;
    font-size: 12px;
    color: #888;
    padding: 0 20px;
    line-height: 40px;
  }

  /* NEWS TICKER */
  .news-bar {
    background: #111111;
    display: flex;
    align-items: center;
    overflow: hidden;
    height: 38px;
    border-bottom: 2px solid var(--color-terra);
    position: relative;
    z-index: 10;
  }

  .news-track-wrap {
    flex: 1;
    overflow: hidden;
    height: 100%;
    position: relative;
  }

  .news-track {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    display: flex;
    align-items: center;
    white-space: nowrap;
  }

  @keyframes newsScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* JS-injected news elements need :global() */
  :global(.news-scroll) { display: inline-flex; align-items: center; white-space: nowrap; }
  :global(.news-track:hover .news-scroll) { animation-play-state: paused; }
  :global(.news-item) {
    display: inline-block;
    font-size: 13px;
    font-weight: 500;
    color: #fff;
    padding: 0 22px;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.2s;
    white-space: nowrap;
  }
  :global(.news-item:hover) { color: var(--color-terra-lt); text-decoration: none; }
  :global(.news-sep) { color: var(--color-terra); font-size: 10px; padding: 0 2px; opacity: 0.9; }
  :global(.news-loading) { font-size: 12px; color: #666; padding: 0 16px; }

  /* MEMBERSHIP SECTION */
  .membership-section {
