---
const navLinks = [
  { href: '/blog',      en: 'Articles',      es: 'Artículos' },
  { href: '/money',     en: 'Global Money',  es: 'Dinero Global' },
  { href: '/goods',     en: 'Global Goods',  es: 'Productos' },
  { href: '/travel',    en: 'Travel',        es: 'Viajes' },
  { href: '/about',     en: 'About',         es: 'Nosotros' },
];
---
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="/images/logo.png" alt="GeoPueblo" class="nav-logo-img" />
    </a>
    <ul class="nav-links">
      {navLinks.map(link => (
        <li>
          <a href={link.href}>
            <span class="t-en">{link.en}</span>
            <span class="t-es" style="display:none">{link.es}</span>
          </a>
        </li>
      ))}
    </ul>
    <button class="lang-toggle" id="langToggle" aria-label="Switch language">
      <span class="lang-en">🇺🇸 EN</span>
      <span class="lang-es" style="display:none">🇻🇪 ES</span>
    </button>
    <a href="#subscribe" class="nav-cta">
      <span class="t-en">Join the village</span>
      <span class="t-es" style="display:none">Únete al pueblo</span>
    </a>
  </div>
</nav>
<script>
  const saved = localStorage.getItem('gp-lang') || 'en';
  let currentLang = saved;
  function applyLang(lang: string) {
    currentLang = lang;
    localStorage.setItem('gp-lang', lang);
    document.querySelectorAll('.t-en').forEach(el => {
      (el as HTMLElement).style.display = lang === 'en' ? '' : 'none';
    });
    document.querySelectorAll('.t-es').forEach(el => {
      (el as HTMLElement).style.display = lang === 'es' ? '' : 'none';
    });
    const btnEn = document.querySelector('.lang-en') as HTMLElement;
    const btnEs = document.querySelector('.lang-es') as HTMLElement;
    if (btnEn) btnEn.style.display = lang === 'en' ? '' : 'none';
    if (btnEs) btnEs.style.display = lang === 'es' ? '' : 'none';
    document.documentElement.lang = lang;
  }
  applyLang(currentLang);
  document.getElementById('langToggle')?.addEventListener('click', () => {
    applyLang(currentLang === 'en' ? 'es' : 'en');
  });
</script>
<style>
  .nav {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 10;
    padding: 1rem 2rem;
  }
  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .nav-logo {
    display: block;
    text-decoration: none;
    margin-right: auto;
    flex-shrink: 0;
  }
  .nav-logo-img {
    width: 90px;
    height: 90px;
    display: block;
    border-radius: 12px;
    transition: opacity 0.2s;
  }
  .nav-logo:hover .nav-logo-img {
    opacity: 0.85;
  }
  .nav-links {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }
  .nav-links a {
    color: rgba(255,255,255,0.85);
    font-size: 14px;
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--color-terra-lt);
    text-decoration: none;
  }
  .lang-toggle {
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5px;
    padding: 6px 12px;
    border-radius: 20px;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
    font-family: var(--font-main);
  }
  .lang-toggle:hover {
    background: rgba(255,255,255,0.22);
  }
  .nav-cta {
    background: var(--color-terra-lt);
    color: var(--color-dark);
    font-size: 14px;
    font-weight: 500;
    padding: 8px 18px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-cta:hover {
    background: #fff;
    text-decoration: none;
  }
  @media (max-width: 640px) {
    .nav-links { display: none; }
    .nav-logo-img { width: 68px; height: 68px; }
  }
</style>
