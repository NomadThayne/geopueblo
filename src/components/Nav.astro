---
const navLinks = [
  { href: '/blog', label: 'Articles' },
  { href: '/money', label: 'Global Money' },
  { href: '/culture', label: 'Culture' },
  { href: '/about', label: 'About' },
];
---

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">GeoPueblo</a>
    <ul class="nav-links">
      {navLinks.map(link => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
    <a href="#subscribe" class="nav-cta">Join the village</a>
  </div>
</nav>

<style>
  .nav {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    padding: 1.25rem 2rem;
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-logo {
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    letter-spacing: 0.5px;
    text-decoration: none;
    margin-right: auto;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    color: rgba(255,255,255,0.85);
    font-size: 14px;
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--color-terra-lt);
    text-decoration: none;
  }

  .nav-cta {
    background: var(--color-terra-lt);
    color: var(--color-dark);
    font-size: 14px;
    font-weight: 500;
    padding: 8px 18px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-cta:hover {
    background: #fff;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .nav-links { display: none; }
  }
</style>
